# =============================================================================
#  AIMHIGHER AI — ENVIRONMENT TEMPLATE
#  Copy to .env and fill in values. NEVER commit to version control.
# =============================================================================

# INFRASTRUCTURE - Generate secure random values
POSTGRES_PASSWORD=generate-strong-random-password-here
REDIS_PASSWORD=generate-strong-random-password-here
SECRET_KEY=generate-32-character-random-string-here

# DATABASE
DATABASE_URL=postgresql://aimhigher:POSTGRES_PASSWORD@postgres:5432/aimhigher

# FRONTEND (update for production)
FRONTEND_URL=http://localhost:3000

# AI APIs - Get from https://aistudio.google.com/apikey and https://platform.openai.com/api-keys
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# FRONTEND ENVIRONMENT
NEXT_PUBLIC_API_URL=http://localhost:8000

